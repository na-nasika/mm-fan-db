---
const { title = 'MZM Fan Archive' } = Astro.props;
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #12101c;
      --surface: #1d1a2b;
      --surface-hover: #262238;
      --text: #f1ecfa;
      --text-muted: #9691b3;
      --accent-cyan: #22d3ee;
      --accent-violet: #8b5cf6;
      --accent-magenta: #ec4899;
      --accent-moon: #ffd166;
      --border: #2c2840;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: 'Zen Kaku Gothic New', sans-serif;
      line-height: 1.6;
    }

    a { color: inherit; text-decoration: none; }

    .site-header {
      padding: 2rem 1.5rem 1rem;
      text-align: center;
      border-bottom: 1px solid var(--border);
    }

    .site-header h1 {
      font-family: 'Bebas Neue', sans-serif;
      letter-spacing: 0.08em;
      font-size: clamp(1.8rem, 5vw, 2.6rem);
      margin: 0;
      background: linear-gradient(135deg, var(--accent-cyan), var(--accent-violet), var(--accent-magenta));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .site-header p {
      color: var(--text-muted);
      font-size: 0.9rem;
      margin: 0.4rem 0 0;
    }

    main {
      max-width: 900px;
      margin: 0 auto;
      padding: 1.5rem;
    }

    a:focus-visible, button:focus-visible, input:focus-visible, select:focus-visible {
      outline: 2px solid var(--accent-cyan);
      outline-offset: 2px;
    }

    @media (prefers-reduced-motion: reduce) {
      * { animation: none !important; transition: none !important; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <h1>MZM Fan Archive</h1>
    <p>非公式ファンメイド動画アーカイブ</p>
  </header>
  <main>
    <slot />
  </main>
</body>
</html>